# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inl_portal
DB_USER=postgres
DB_PASSWORD=your_password

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_min_32_chars_here!!
JWT_EXPIRES_IN=8h

# ─── SSO Token (short-lived token saat redirect ke aplikasi SSO) ──────────────
SSO_TOKEN_EXPIRES_IN=5m

# ─── File Upload ───────────────────────────────────────────────────────────────
# Folder lokal tempat file disimpan (relatif dari root project)
UPLOAD_DIR=uploads
# Base URL untuk akses file dari client
UPLOAD_URL=http://localhost:3000/uploads

# ─── Seed Admin ────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@inl.co.id
SEED_ADMIN_PASSWORD=Admin@123

# ─── WebAuthn / Passkey ────────────────────────────────────────────────────────
# Domain utama (tanpa http/https/port/path)
WEBAUTHN_RP_ID=portal-fe.vercel.app

# Nama aplikasi/organisasi yang muncul di layar browser user
WEBAUTHN_RP_NAME="PT Industri Nabati Lestari"

# URL lengkap asal (Origin) frontend yang diizinkan memicu WebAuthn (tanpa trailing slash di ujung)
WEBAUTHN_EXPECTED_ORIGINS=https://portal-fe.vercel.app
