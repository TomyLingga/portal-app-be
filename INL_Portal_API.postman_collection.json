    {
      "name": "SSO",
      "item": [
        {
          "name": "Generate SSO Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.token) {",
                  "  pm.collectionVariables.set('sso_token', res.data.token);",
                  "  console.log('SSO Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/sso/token?app_id=uuid-app-disini",
              "host": ["{{base_url}}"],
              "path": ["api", "sso", "token"],
              "query": [{ "key": "app_id", "value": "uuid-app-disini" }]
            }
          }
        },
        {
          "name": "Verify SSO Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{sso_token}}\",\n  \"app_id\": \"uuid-app-disini\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sso/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "sso", "verify"]
            }
          }
        }
      ]
    },
