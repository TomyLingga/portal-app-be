{
  "info": {
    "name": "INL Portal API",
    "description": "REST API for INL Portal — Fastify + TypeScript + Drizzle ORM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "sso_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  console.log('Access token and Refresh token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@inl.co.id\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
                  "  console.log('Tokens refreshed and saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users?page=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "role", "value": "user", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@inl.co.id\",\n  \"password\": \"Password1\",\n  \"role\": \"user\",\n  \"isActive\": true,\n  \"employeeId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "uuid-disini" }]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"super_admin\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "uuid-disini" }]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/users/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "uuid-disini" }]
            }
          }
        },
        {
          "name": "Get User Apps",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/:id/apps",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id", "apps"],
              "variable": [{ "key": "id", "value": "uuid-disini" }]
            }
          }
        },
        {
          "name": "Grant App Access",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appId\": \"uuid-app-disini\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/:id/grant-app",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id", "grant-app"],
              "variable": [{ "key": "id", "value": "uuid-disini" }]
            }
          }
        },
        {
          "name": "Revoke App Access",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/users/:id/revoke-app/:appId",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ":id", "revoke-app", ":appId"],
              "variable": [
                { "key": "id", "value": "uuid-user" },
                { "key": "appId", "value": "uuid-app" }
              ]
            }
          }
        }
      ]
    },
